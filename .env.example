# =========================
# Core Django settings
# =========================
SECRET_KEY=change-me
DEBUG=True
TIME_ZONE=Europe/Moscow

# Хосты/URL
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_BASE_URL=http://localhost:5173
# Для POST из браузера с фронта (:5173). При другом хосте допишите origin-ы:
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
# Только dev (next_refuels.settings.dev): CORS для фронта на 5173 -> API на 8000
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Сессии/CSRF
SESSION_COOKIE_AGE=28800
SESSION_SAVE_EVERY_REQUEST=True
CSRF_COOKIE_HTTPONLY=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Безопасность (в prod обычно True/не нулевые)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# =========================
# Database
# =========================
DATABASE_URL=postgresql://postgres:postgres@db:5432/next_refuels
DB_SSL_REQUIRE=False
DB_CONN_TIMEOUT=30

POSTGRES_DB=next_refuels
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_PROXY_URL=
TELEGRAM_DROP_PENDING_UPDATES=True
TELEGRAM_ALLOWED_UPDATES=message,callback_query
TELEGRAM_LINK_CODE_TTL_MINUTES=10
# ID чата/пользователя для оповещений об ошибках (логи ERROR -> sendMessage).
# Обычно тот же бот, что и TELEGRAM_BOT_TOKEN.
TELEGRAM_ALERT_CHAT_ID=

# =========================
# Integrations
# =========================
# 1C Element API
ELEMENT_API_URL=https://1c.0nalog.com:1710/Transavto/hs/
ELEMENT_API_USER=your-api-user
ELEMENT_API_PASSWORD=your-api-password

# Планировщик синхронизации автопарка (минуты)
SYNC_CARS_SCHEDULE_MINUTES=30

# =========================
# Auth / SSO / MFA
# =========================
AUTH_THROTTLE_ENABLED=True
AUTH_THROTTLE_LIMIT=5
AUTH_THROTTLE_WINDOW_SECONDS=900
AUTH_THROTTLE_LOCK_SECONDS=1800

AUTH_PROVIDER=local
SSO_METADATA_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
MFA_POLICY_ENABLED=False

# =========================
# Email
# =========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
SERVER_EMAIL=
DEFAULT_FROM_EMAIL=

# =========================
# Superuser bootstrap
# =========================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# =========================
# Production only
# =========================
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=admin@example.com
# Прод: один хост в браузере — фронт /, API /api/, админка /admin/ (nginx -> Django).
# ALLOWED_HOSTS=your-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
