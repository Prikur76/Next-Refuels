FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    curl \
    libpq-dev \
    tzdata \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app
COPY pyproject.toml /app/
RUN python -c "import tomllib; d=tomllib.load(open('pyproject.toml','rb')); req='\\n'.join(d['project']['dependencies']); open('/tmp/req.txt','w',encoding='utf-8').write(req+'\\n')" \
    && pip install --no-cache-dir -r /tmp/req.txt

COPY . /app

# Создать каталоги для статики
RUN mkdir -p /app/static /app/media

COPY scripts/entrypoint.dev.sh /entrypoint.sh
# Windows checkouts часто дают CRLF; без этого ядро ищет /bin/bash\r
RUN sed -i 's/\r$//' /entrypoint.sh && chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
