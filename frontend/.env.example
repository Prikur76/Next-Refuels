# Локально: админка Django — http://<HOST>:8000/admin
# Фронт Next.js — http://<HOST>:5173 (npm run dev)
#
# Вариант A — запросы к API через прокси Next (rewrites в next.config.mjs):
#   NEXT_PUBLIC_API_URL=
#   В Docker для SSR дополнительно: NEXT_INTERNAL_API_URL=http://web:8000
#
# Вариант B — браузер ходит на Django напрямую (нужен CORS в dev, см. .env корня):
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_INTERNAL_API_URL=http://web:8000

# Опционально: IANA-пояс, если до загрузки /auth/me нужен тот же календарь, что TIME_ZONE в Django.
# NEXT_PUBLIC_APP_TIME_ZONE=Europe/Moscow

# Порог (литры): заправки обычных авто (не ТЗ) с объёмом строго выше — красная подсветка в журнале и «Мои заправки».
# NEXT_PUBLIC_FUEL_SUSPICIOUS_LITERS_THRESHOLD=80

# Прод за nginx: тот же хост, что и у сайта — оставьте пустым (относительные /api/...).
# NEXT_PUBLIC_API_URL=

# Dev: Django admin на другом порту.
# Для prod можно оставить пустым — будет использован относительный `/admin/`.
NEXT_PUBLIC_DJANGO_ADMIN_URL=http://localhost:8000/admin/
